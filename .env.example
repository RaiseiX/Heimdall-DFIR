# ─── ForensicLab Environment Configuration ───
# Copy this file to .env and fill in REAL values — never commit .env to git!

# Database
DB_PASSWORD=CHANGEME_min32chars_random

# Redis
REDIS_PASSWORD=CHANGEME_min32chars_random

# JWT Authentication — generate with: openssl rand -hex 64
JWT_SECRET=CHANGEME_generate_with_openssl_rand_hex_64

# Allowed CORS origins (comma-separated, no trailing slash)
ALLOWED_ORIGINS=http://localhost:3000

# App
NODE_ENV=production
UPLOAD_MAX_SIZE=5368709120  # 5GB

# VolWeb (Volatility 3 RAM analysis — M5)
VOLWEB_DJANGO_SECRET=CHANGEME_min50chars_random_string
VOLWEB_USER=admin
VOLWEB_PASSWORD=CHANGEME_min16chars_volweb
VOLWEB_URL=http://hel-api:8000
VOLWEB_PUBLIC_URL=http://localhost:8888

# MinIO (object storage for VolWeb)
MINIO_ROOT_USER=CHANGEME_access_key_id
MINIO_ROOT_PASSWORD=CHANGEME_min12chars_secret_key

# VolWeb YARA scan worker resource limits (v3.16.0+)
YARASCAN_CPU_LIMIT=2
YARASCAN_MEM_LIMIT=4G

# Docker socket GID — dashboard infra (dockerode)
# Obtenir avec : stat -c %g /var/run/docker.sock  (souvent 999 ou 998)
DOCKER_GID=999

# Ollama / AI Copilot — optionnel, fonctionnalité désactivée si OLLAMA_URL absent
# Lancer le service ollama dans docker-compose : docker compose --profile ai up
OLLAMA_URL=http://ollama:11434
AI_ENABLED=true
AI_MODEL=qwen3:14b
AI_MAX_HISTORY_MESSAGES=30
AI_TEMPERATURE=0.1
AI_NO_THINK_MODE=true
AI_MAX_CONTEXT_CHARS=4000

# IOC Enrichissement — optionnel, enrichissement désactivé si absent
# VirusTotal : https://www.virustotal.com/gui/my-apikey
VIRUSTOTAL_API_KEY=
# AbuseIPDB : https://www.abuseipdb.com/account/api
ABUSEIPDB_API_KEY=

# GitHub — optionnel, augmente le rate limit API de 60 à 5 000 req/h
# Créer un classic token sur https://github.com/settings/tokens (aucun scope requis pour repos publics)
GITHUB_TOKEN=
