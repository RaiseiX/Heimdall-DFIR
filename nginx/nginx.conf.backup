worker_processes auto;
events {
    worker_connections 1024;
}

http {
    # WebSocket / long-polling Connection header map
    # WebSocket req → Connection: upgrade ; HTTP polling req → Connection: close
    map $http_upgrade $connection_upgrade {
        default upgrade;
        ''      close;
    }

    include       /etc/nginx/mime.types;
    default_type  application/octet-stream;

    # Logging
    log_format main '$remote_addr - $remote_user [$time_local] "$request" '
                    '$status $body_bytes_sent "$http_referer" '
                    '"$http_user_agent"';
    access_log /var/log/nginx/access.log main;
    error_log  /var/log/nginx/error.log warn;

    # Performance
    sendfile           on;
    tcp_nopush         on;
    tcp_nodelay        on;
    keepalive_timeout  65;
    gzip on;
    gzip_types text/plain text/css application/json application/javascript text/xml;

    # Hide server version
    server_tokens off;

    # Security Headers
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;
    add_header Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=(), usb=()" always;
    # HSTS — uncomment once TLS is configured (nginx/ssl/ certs in place):
    # add_header Strict-Transport-Security "max-age=31536000; includeSubDomains; preload" always;
    add_header Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: blob:; font-src 'self' data: https://fonts.gstatic.com; connect-src 'self' ws: wss:; worker-src 'self' blob:;" always;

    # Mask backend implementation headers
    proxy_hide_header X-Powered-By;
    proxy_hide_header Server;

    # Default body size (overridden per-location below)
    client_max_body_size 60M;

    # Timeout tuning for long-running parser jobs
    proxy_read_timeout   600s;
    proxy_send_timeout   600s;
    proxy_connect_timeout 10s;

    # Rate limiting zones
    limit_req_zone $binary_remote_addr zone=api:10m  rate=30r/s;
    limit_req_zone $binary_remote_addr zone=auth:10m rate=5r/m;

    server {
        listen 80;
        server_name _;

        # Docker internal DNS — re-resolves every 30 s.
        # Using variables in proxy_pass forces dynamic resolution so container
        # rebuilds (new IPs) never cause 502 errors.
        resolver 127.0.0.11 valid=30s;
        set $backend  "backend:4000";
        set $frontend "frontend:3000";

        # ── Socket.io (WebSocket + long-polling) ──────────────
        # Must come BEFORE the generic /api/ block so Nginx matches it first.
        location /socket.io/ {
            proxy_pass         http://$backend/socket.io/;
            proxy_http_version 1.1;

            # WebSocket handshake headers
            proxy_set_header Upgrade    $http_upgrade;
            proxy_set_header Connection $connection_upgrade;

            proxy_set_header Host              $host;
            proxy_set_header X-Real-IP         $remote_addr;
            proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;

            # Keep WebSocket connections alive for long parser runs
            proxy_read_timeout  3600s;
            proxy_send_timeout  3600s;

            # Disable buffering for real-time events
            proxy_buffering    off;
            proxy_cache        off;
        }

        # ── Chunked upload (no body size limit, no request buffering) ──
        location /api/upload/ {
            limit_req zone=api burst=20 nodelay;

            proxy_pass               http://$backend/api/upload/;
            proxy_http_version       1.1;
            proxy_set_header Host              $host;
            proxy_set_header X-Real-IP         $remote_addr;
            proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;

            # Critical: disable buffering so chunks are streamed to backend
            proxy_request_buffering  off;
            proxy_buffering          off;

            # No size limit — backend enforces per-chunk limit (55 MB)
            client_max_body_size     0;

            # Long timeout for huge files
            proxy_read_timeout       1800s;
            proxy_send_timeout       1800s;
        }

        # ── Collection import (large ZIPs, long-running processing) ──
        # Must come BEFORE /api/ so nginx matches it first.
        # client_max_body_size 0 → multer enforces the 10 GB limit on the backend.
        # proxy_request_buffering off → large file streams directly to backend
        #   instead of being buffered to nginx's temp disk first (avoids double I/O).
        # Timeouts cover: upload (multi-GB) + unzip + parser execution (can exceed 30 min).
        location /api/collection/ {
            limit_req zone=api burst=5 nodelay;

            proxy_pass               http://$backend/api/collection/;
            proxy_http_version       1.1;
            # keepAliveTimeout=75s on Node.js (> nginx keepalive_timeout 65s) ensures
            # idle connections never expire before nginx can reuse them → no stale-
            # connection 499. We can safely use keepalive here.
            proxy_set_header Connection "";
            proxy_set_header Host              $host;
            proxy_set_header X-Real-IP         $remote_addr;
            proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;

            client_max_body_size     0;
            proxy_request_buffering  off;
            proxy_buffering          off;

            proxy_read_timeout       7200s;
            proxy_send_timeout       7200s;
        }

        # ── Auth routes (strict rate limiting) ─────────────────
        location /api/auth/ {
            limit_req zone=auth burst=3 nodelay;
            # proxy_pass without a URI path: Nginx forwards the original
            # request URI unchanged (no suffix stripping).
            proxy_pass         http://$backend;
            proxy_http_version 1.1;
            proxy_set_header   Connection "";
            proxy_set_header Host              $host;
            proxy_set_header X-Real-IP         $remote_addr;
            proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
        }

        # ── General API routes ─────────────────────────────────
        location /api/ {
            limit_req zone=api burst=50 nodelay;

            proxy_pass         http://$backend/api/;
            proxy_http_version 1.1;
            proxy_set_header Connection "";   # enable keep-alive to upstream

            proxy_set_header Host              $host;
            proxy_set_header X-Real-IP         $remote_addr;
            proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;

            proxy_read_timeout 600s;
        }

        # ── React Frontend (with HMR WebSocket support) ────────
        location / {
            proxy_pass         http://$frontend;
            proxy_http_version 1.1;
            proxy_set_header Upgrade    $http_upgrade;
            proxy_set_header Connection $connection_upgrade;
            proxy_set_header Host       $host;
            proxy_set_header X-Real-IP  $remote_addr;
        }
    }
}
