FROM node:20-bookworm-slim

WORKDIR /app

# Install dependencies for Zimmerman tools
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 \
    python3-pip \
    curl \
    file \
    libmagic1 \
    unzip \
    p7zip-full \
    tar \
    gzip \
    ca-certificates \
    gnupg \
    && rm -rf /var/lib/apt/lists/*

# Install mono for .NET Zimmerman tools (optional — won't block startup)
RUN apt-get update && apt-get install -y --no-install-recommends mono-runtime mono-devel || echo "Mono not available — Zimmerman tools will need manual setup" \
    && rm -rf /var/lib/apt/lists/*

COPY package*.json ./
RUN npm install --omit=dev --no-audit --no-fund

COPY . .

RUN mkdir -p /app/uploads /app/uploads/collections /app/evidence /app/zimmerman-tools /app/temp /app/collections

# Script to download Zimmerman tools automatically
COPY download-zimmerman.sh /app/download-zimmerman.sh
RUN chmod +x /app/download-zimmerman.sh

EXPOSE 4000

CMD ["node", "src/server.js"]
