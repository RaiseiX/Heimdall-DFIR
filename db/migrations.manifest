# Heimdall-DFIR — canonical migration order.
# One migration file per line, applied top-to-bottom by db/migrate.sh, each
# recorded once in the schema_migrations table (idempotent).
#
# RULES:
#   - Every db/*.sql and db/migrations/*.sql file (except db/init.sql) MUST be
#     listed here. migrate.sh preflight aborts if any file is missing — this is
#     what prevents a new migration from being silently orphaned.
#   - Append new migrations at the END (do not reorder already-applied entries;
#     schema_migrations tracks by filename, so ordering of applied files is
#     fixed history).
#   - Blank lines and lines starting with '#' are ignored.

# --- legacy v2.x era (tracked on existing deployments) ---
db/migrate_v2.7.sql
db/migrate_v2.8.sql
db/migrate_v2.9.sql
db/migrate_v2.10.sql
db/migrate_v2.11.sql
db/migrate_v2.12.sql
db/migrate_v2.13.sql
db/migrate_v2.14.sql
db/migrate_v2.15.sql
db/migrate_v2.16.sql
db/migrate_v2.17.sql
db/migrate_v2.18.sql
db/migrate_v2.19.sql
db/migrate_v2.20.sql
db/migrate_v2.21.sql
db/migrate_v2.22.sql

