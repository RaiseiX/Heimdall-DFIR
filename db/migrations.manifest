db/migrations/007_risk_score.sql
db/migrations/008_ioc_cross_case_view.sql
db/migrations/009_memory_uploads_fix.sql
db/migrations/010_additional_files.sql
db/migrations/011_investigation_workspace.sql
db/migrations/20260322120000_ai_case_context.sql
db/migrations/20260322140000_report_templates.sql
