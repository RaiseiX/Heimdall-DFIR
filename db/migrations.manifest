db/migrations/20260703000000_dfiq.sql
db/migrations/20260708000000_ingestion_files.sql
db/migrations/20260709000000_hunt_runs.sql

# --- previously-orphaned committed hotfixes (v2.23-v2.27) ---
# Additive to tables that exist by this point; v2.25 creates the workbench
# tables that v2.27 then alters, so v2.25 MUST precede v2.27.
db/migrate_v2.23.sql
